# Copy this file to .env.local and fill in your real values for local development with `vercel dev`.
# Never commit .env.local — it's already in .gitignore.

# Server-side only (used by api/viva.js). Get this at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Client-side, safe to expose (Supabase anon key is public by design; Row Level Security protects data).
# Get these from your Supabase project: Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
